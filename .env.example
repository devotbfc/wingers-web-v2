# Wingers Web .env.example
# Copy to .env.local and fill in real values. Never commit .env.local.
# All values mirrored in Vercel → Settings → Environment Variables.

# ============================================================
# PUBLIC (NEXT_PUBLIC_*) — visible to the browser
# ============================================================

# The absolute URL of this deployment. Initially Vercel preview URL.
# Switch to https://wingers.co at DNS cutover.
# Used for canonical URLs, OG images, sitemap.xml absolute URLs.
NEXT_PUBLIC_APP_URL=https://wingers-web-v2.vercel.app

# Supabase project URL (EU region). Browser-safe.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon key. Browser-safe. Used only for Phase 2 client-side reads.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# ============================================================
# SERVER-ONLY — never exposed to the browser
# ============================================================

# Supabase service role key. SERVER ONLY. Full DB access.
# Used by /api/loyalty/signup and /api/contact route handlers.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Mailchimp API credentials. SERVER ONLY.
# Used to add new loyalty signups to the "Friends with Benefits" audience.
MAILCHIMP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-us12
MAILCHIMP_AUDIENCE_ID=abc123def4
MAILCHIMP_SERVER_PREFIX=us12

# ============================================================
# PHASE 2 — add when implementing analytics / errors / transactional email
# ============================================================

# PostHog (EU instance for UK data residency)
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Sentry
# SENTRY_DSN=https://xxx@oxxx.ingest.sentry.io/xxx
# SENTRY_AUTH_TOKEN=sntrys_xxx

# Resend (transactional email — confirmation, contact form forwarding)
# RESEND_API_KEY=re_xxx
